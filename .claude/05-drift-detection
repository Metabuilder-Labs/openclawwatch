    baseline: DriftBaseline,
    config_threshold: float = 2.0,
    sequence_diff_threshold: float = 0.4,
    db: StorageBackend | None = None,
) -> DriftResult:
    """
    Compare a completed session against the baseline.
    Returns DriftResult with list of violations and whether drift was detected.

    Checks:
    1. Input token Z-score > config_threshold
    2. Output token Z-score > config_threshold
    3. Session duration Z-score > config_threshold
    4. Tool call count Z-score > config_threshold
    5. Jaccard similarity of session tools vs baseline tools < (1 - sequence_diff_threshold)
