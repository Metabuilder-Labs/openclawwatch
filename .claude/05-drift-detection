def z_score(value: float, mean: float, stddev: float) -> float:
    """Standard Z-score. Returns 0.0 if stddev is 0 to avoid division by zero."""
    if stddev == 0:
        return 0.0
    return (value - mean) / stddev


def jaccard_similarity(set_a: set, set_b: set) -> float:
    """
    Jaccard similarity between two sets.
    Returns 1.0 if both sets are empty (identical).
    Returns 0.0 if one set is empty and the other is not.
    """
    if not set_a and not set_b:
        return 1.0
    union = set_a | set_b
    if not union:
        return 1.0
    return len(set_a & set_b) / len(union)


